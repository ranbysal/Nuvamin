{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": { "includeFiles": ["404.html"] }
    },
    { "src": "assets/**", "use": "@vercel/static" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "robots.txt", "use": "@vercel/static" },
    { "src": "sitemap.xml", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/.*", "dest": "/api/index.js" },
    { "src": "/checkout/.*", "dest": "/api/index.js" },
    { "src": "/admin/.*", "dest": "/api/index.js" },
    { "src": "/mock-hosted(/.*)?", "dest": "/api/index.js" },
    { "handle": "filesystem" },
    { "src": "/([a-z0-9-]+)", "dest": "/$1.html", "check": true },
    { "src": "/(.*)", "dest": "/404.html", "status": 404 }
  ]
}
