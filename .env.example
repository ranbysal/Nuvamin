# ============================================================================
#  NUVAMIN — checkout / payment environment
#  Copy to ".env" and fill in LIVE values. NEVER commit the real .env.
#  The site never sees or stores card data; all card entry happens on the
#  gateway's hosted, PCI-compliant payment page (redirect flow).
# ============================================================================

# ---- App ----
PORT=3000
# Public base URL of the deployed site (used to build return/webhook URLs).
# LIVE: set to your real domain, e.g. https://nuvamin.com
PUBLIC_BASE_URL=http://localhost:3000

# Which payment provider adapter to load: "nmi" | "authorizenet" | "mock"
# "mock" runs a fully simulated hosted page so the flow is testable with no
# real credentials. Set to "nmi" once the NMI values below are filled in.
PAYMENT_PROVIDER=mock

# ---- NMI (Network Merchants Inc.) — hosted "Collect Checkout" redirect ----
# LIVE CREDENTIALS GO HERE  ▼▼▼  (obtain from your NMI merchant portal)
NMI_API_URL=https://secure.nmi.com/api/transact.php
NMI_CHECKOUT_URL=https://secure.nmi.com/api/v4/checkouts
# Processor / gateway account identifier (a.k.a. merchant/gateway ID)
NMI_PROCESSOR_ACCOUNT_ID=REPLACE_WITH_NMI_PROCESSOR_ACCOUNT_ID
# Security key (private API key from NMI → Settings → Security Keys)
NMI_SECURITY_KEY=REPLACE_WITH_NMI_SECURITY_KEY
# Webhook signing secret (NMI → Settings → Webhooks → Signing Secret)
NMI_WEBHOOK_SECRET=REPLACE_WITH_NMI_WEBHOOK_SECRET

# ---- Authorize.Net (future swap — adapter stub already wired) ----
AUTHNET_API_LOGIN_ID=REPLACE_WITH_AUTHNET_API_LOGIN_ID
AUTHNET_TRANSACTION_KEY=REPLACE_WITH_AUTHNET_TRANSACTION_KEY
AUTHNET_SIGNATURE_KEY=REPLACE_WITH_AUTHNET_SIGNATURE_KEY
AUTHNET_ENV=sandbox

# ---- Return URLs (where the gateway sends the customer back) ----
# Defaults are derived from PUBLIC_BASE_URL; override only if you need to.
CHECKOUT_SUCCESS_PATH=/checkout/success
CHECKOUT_CANCEL_PATH=/checkout/cancel
WEBHOOK_PATH=/api/webhook/payment

# ---- Email receipts (SMTP) ----
# Leave blank to run in "log to console" mode (no real email sent).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
RECEIPT_FROM="Nuvamin <orders@nuvamin.com>"

# ---- Admin ----
# Bearer token protecting the admin order-records endpoint.
ADMIN_TOKEN=REPLACE_WITH_A_LONG_RANDOM_ADMIN_TOKEN

# ---- Currency ----
CURRENCY=EUR
