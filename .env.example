# ============================================================================
#  NUVAMIN — checkout / payment environment
#  Copy to ".env" and fill in LIVE values. NEVER commit the real .env.
#  The site never sees or stores card data; all card entry happens on the
#  gateway's hosted, PCI-compliant payment page (redirect flow).
# ============================================================================

# ---- App ----
PORT=3000
# Public base URL of the deployed site (used to build return/webhook URLs).
# LIVE: set to your real domain, e.g. https://nuvamin.bio
PUBLIC_BASE_URL=http://localhost:3000

# Which payment provider adapter to load: "nmi" | "authorizenet" | "mock"
# "mock" runs a fully simulated hosted page so the flow is testable with no
# real credentials. Set to "nmi" once the NMI values below are filled in.
# NOTE: "mock" refuses to start in production unless ALLOW_MOCK_GATEWAY=true
# (staging demos only — mock payments are forgeable by design).
PAYMENT_PROVIDER=mock

# ---- Order storage ----
# "file"  — JSON file at server/data/orders.json (local dev / single host)
# "redis" — Upstash Redis (REQUIRED on Vercel; the filesystem there is ephemeral)
# Defaults to "redis" automatically when the Upstash variables below exist.
# On Vercel: add the Upstash Redis integration (Storage tab) and these two
# variables are injected for you — nothing to fill in by hand.
ORDER_STORE=file
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- NMI (Network Merchants Inc.) — hosted "Collect Checkout" redirect ----
# LIVE CREDENTIALS GO HERE  ▼▼▼  (obtain from your NMI merchant portal)
NMI_CHECKOUT_URL=https://secure.nmi.com/api/v4/checkouts
# Processor / gateway account identifier (a.k.a. merchant/gateway ID)
NMI_PROCESSOR_ACCOUNT_ID=REPLACE_WITH_NMI_PROCESSOR_ACCOUNT_ID
# Security key (private API key from NMI → Settings → Security Keys)
NMI_SECURITY_KEY=REPLACE_WITH_NMI_SECURITY_KEY
# Webhook signing secret (NMI → Settings → Webhooks → Signing Secret)
NMI_WEBHOOK_SECRET=REPLACE_WITH_NMI_WEBHOOK_SECRET

# ---- Authorize.Net (future swap — adapter stub already wired) ----
AUTHNET_API_LOGIN_ID=REPLACE_WITH_AUTHNET_API_LOGIN_ID
AUTHNET_TRANSACTION_KEY=REPLACE_WITH_AUTHNET_TRANSACTION_KEY
AUTHNET_SIGNATURE_KEY=REPLACE_WITH_AUTHNET_SIGNATURE_KEY
AUTHNET_ENV=sandbox

# ---- Return URLs (where the gateway sends the customer back) ----
# Defaults are derived from PUBLIC_BASE_URL; override only if you need to.
CHECKOUT_SUCCESS_PATH=/checkout/success
CHECKOUT_CANCEL_PATH=/checkout/cancel
WEBHOOK_PATH=/api/webhook/payment

# ---- Email (SMTP) — receipts, order notifications, contact form ----
# Leave blank to run in "log to console" mode (no real email sent).
#
# GOOGLE WORKSPACE (Gmail custom domain) — see GOOGLE-WORKSPACE-SETUP.md:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_USER=labs@nuvamin.bio               (the Workspace mailbox)
#   SMTP_PASS=xxxx xxxx xxxx xxxx            (a Gmail APP PASSWORD, not the login password)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# The From identity on all outgoing mail (must be the Workspace address or an
# alias of it, or Gmail will rewrite/reject it).
RECEIPT_FROM="Nuvamin <labs@nuvamin.bio>"
# Shown to customers as the support address (site pages + receipt footer).
SUPPORT_EMAIL=support@nuvamin.bio
# Where contact-form messages are delivered (defaults to SUPPORT_EMAIL).
CONTACT_TO=support@nuvamin.bio
# Where "new paid order" notifications are delivered (defaults to SUPPORT_EMAIL).
ORDER_NOTIFY_EMAIL=labs@nuvamin.bio

# ---- Google Sheets order log (optional but recommended) ----
# Deployed Apps Script web-app URL bound to the client's spreadsheet, plus a
# shared secret that must match the SECRET constant inside the script.
# Full copy-paste setup: GOOGLE-WORKSPACE-SETUP.md
SHEETS_WEBHOOK_URL=
SHEETS_WEBHOOK_SECRET=

# ---- The Lot Report mailing list (second Apps Script web app) ----
# Newsletter signups post here; the script adds them to the subscribers sheet
# and sends the welcome email (with the first-order code) from the client's
# Gmail. The secret also signs unsubscribe links. Setup: GOOGLE-WORKSPACE-SETUP.md
SUBSCRIBERS_WEBHOOK_URL=
SUBSCRIBERS_WEBHOOK_SECRET=

# First-order discount advertised in the welcome email. Keep these in sync
# with DISCOUNT_CODE / DISCOUNT_PERCENT in google/nuvamin-subscribers.gs.
FIRST_ORDER_DISCOUNT_CODE=LOT10
FIRST_ORDER_DISCOUNT_PERCENT=10

# ---- Admin ----
# Bearer token protecting the admin order-records endpoint.
ADMIN_TOKEN=REPLACE_WITH_A_LONG_RANDOM_ADMIN_TOKEN

# ---- Currency ----
CURRENCY=USD
